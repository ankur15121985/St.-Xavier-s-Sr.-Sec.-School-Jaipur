rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // 0. Global Safety Net & Catch-all
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Global Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Allow if document exists OR if it's the verified primary user email
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "ankur15121985@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // 1. Admins Collection
    // -------------------------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // 2. Collections
    // -------------------------------------------------------------------------
    
    // Generic helper for admin write access
    function canWritePublic() {
      return isAdmin();
    }

    // Rule for most public read, admin write collections
    match /notices/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /staff/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /gallery/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /carousel/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /fees/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /links/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /events/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /achievements/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /studentHonors/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /menu/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /faqs/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /settings/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /content/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /popups/{id} { allow read: if true; allow write: if canWritePublic(); }
    match /transfer_certificates/{id} { allow read: if true; allow write: if canWritePublic(); }
    
    match /messages/{id} {
      allow create: if true; // Public can send messages
      allow read, update, delete: if isAdmin();
    }
  }
}
