rules_version = '2';
service firebase.storage {
  match /b/{bubble}/o {
    match /{allPaths=**} {
      // Allow public read access to all files
      allow read: if true;
      
      // Allow write access only to authenticated admins
      allow write: if request.auth != null && (
        request.auth.token.email == "ankur15121985@gmail.com"
      );
    }
  }
}
