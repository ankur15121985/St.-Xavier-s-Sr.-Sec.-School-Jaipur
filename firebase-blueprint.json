{
  "entities": {
    "Notice": {
      "title": "School Notice",
      "description": "Important school announcements and circulars",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "link": { "type": "string" },
        "attachmentUrl": { "type": "string" }
      },
      "required": ["title", "date", "category"]
    },
    "StaffMember": {
      "title": "Staff Member",
      "description": "Faculty and administration members",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "image": { "type": "string" },
        "type": { "type": "string", "enum": ["Management", "Faculty", "Administration"] }
      },
      "required": ["name", "role", "type"]
    },
    "GalleryItem": {
      "title": "Gallery Item",
      "description": "Media item for gallery or carousel",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "caption": { "type": "string" }
      },
      "required": ["url"]
    },
    "FeeStructure": {
      "title": "Fee Structure",
      "description": "Academic fee details by grade",
      "type": "object",
      "properties": {
        "grade": { "type": "string" },
        "admissionFee": { "type": "string" },
        "tuition_fees": { "type": "string" },
        "quarterly": { "type": "string" },
        "attachmentUrl": { "type": "string" }
      },
      "required": ["grade"]
    },
    "QuickLink": {
      "title": "Quick Link",
      "description": "Resource links for portals and documents",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string" },
        "attachmentUrl": { "type": "string" }
      },
      "required": ["title", "url"]
    },
    "Event": {
      "title": "School Event",
      "description": "Upcoming events and activities",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "location": { "type": "string" },
        "attachmentUrl": { "type": "string" }
      },
      "required": ["title", "date"]
    },
    "Achievement": {
      "title": "Achievement",
      "description": "School success stories and awards",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "year": { "type": "string" },
        "description": { "type": "string" },
        "attachmentUrl": { "type": "string" }
      },
      "required": ["title", "year"]
    },
    "StudentHonor": {
      "title": "Student Honor",
      "description": "Student academic and extracurricular recognitions",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "result": { "type": "string" },
        "subtext": { "type": "string" },
        "image": { "type": "string" },
        "order_index": { "type": "number" }
      },
      "required": ["name", "category", "result"]
    },
    "MenuItem": {
      "title": "Menu Item",
      "description": "Navigation menu configuration",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "href": { "type": "string" },
        "parent_id": { "type": "string" },
        "order_index": { "type": "number" }
      },
      "required": ["label", "href", "order_index"]
    },
    "Admin": {
      "title": "System Admin",
      "description": "Users with administrative write access",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      }
    },
    "Question": {
      "title": "FAQ Entry",
      "description": "A question and its corresponding answer",
      "type": "object",
      "properties": {
        "question": { "type": "string" },
        "answer": { "type": "string" },
        "category": { "type": "string" },
        "order_index": { "type": "number" }
      },
      "required": ["question", "answer"]
    },
    "Message": {
      "title": "Contact Message",
      "description": "User inquiry from contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "read", "replied"] }
      },
      "required": ["name", "email", "message"]
    }
  },
  "firestore": {
    "notices": { "schema": "Notice", "description": "Collection of school notices" },
    "staff": { "schema": "StaffMember", "description": "Collection of staff members" },
    "gallery": { "schema": "GalleryItem", "description": "Collection of gallery images" },
    "carousel": { "schema": "GalleryItem", "description": "Collection of homepage carousel images" },
    "fees": { "schema": "FeeStructure", "description": "Collection of fee structures" },
    "links": { "schema": "QuickLink", "description": "Collection of student links" },
    "events": { "schema": "Event", "description": "Collection of calendar events" },
    "achievements": { "schema": "Achievement", "description": "Collection of school achievements" },
    "studentHonors": { "schema": "StudentHonor", "description": "Collection of student honors" },
    "menu": { "schema": "MenuItem", "description": "Collection of navigation menu items" },
    "admins": { "schema": "Admin", "description": "Authorized administrators" },
    "faqs": { "schema": "Question", "description": "Frequently Asked Questions" },
    "messages": { "schema": "Message", "description": "Contact form submissions" }
  }
}
