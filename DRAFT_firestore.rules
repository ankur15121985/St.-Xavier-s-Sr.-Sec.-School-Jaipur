rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---

    function isValidNotice(data) {
      return data.keys().hasAll(['title', 'date', 'category']) &&
             data.title is string && data.title.size() <= 200 &&
             data.date is string && data.date.size() <= 100 &&
             data.category is string && data.category.size() <= 100 &&
             (!('content' in data) || (data.content is string && data.content.size() <= 5000)) &&
             (!('link' in data) || (data.link is string && data.link.size() <= 1024)) &&
             (!('attachmentUrl' in data) || (data.attachmentUrl is string && data.attachmentUrl.size() <= 1024));
    }

    function isValidStaff(data) {
      return data.keys().hasAll(['name', 'role', 'type']) &&
             data.name is string && data.name.size() <= 200 &&
             data.role is string && data.role.size() <= 200 &&
             data.type in ['Management', 'Faculty', 'Administration'] &&
             (!('bio' in data) || (data.bio is string && data.bio.size() <= 2000)) &&
             (!('image' in data) || (data.image is string && data.image.size() <= 1024));
    }

    function isValidGalleryItem(data) {
      return data.keys().hasAll(['url']) &&
             data.url is string && data.url.size() <= 1024 &&
             (!('caption' in data) || (data.caption is string && data.caption.size() <= 500));
    }

    function isValidFee(data) {
      return data.keys().hasAll(['grade', 'admissionFee', 'tuition_fees', 'quarterly']) &&
             data.grade is string && data.grade.size() <= 100 &&
             data.admissionFee is string && data.admissionFee.size() <= 100 &&
             data.tuition_fees is string && data.tuition_fees.size() <= 100 &&
             data.quarterly is string && data.quarterly.size() <= 100 &&
             (!('attachmentUrl' in data) || (data.attachmentUrl is string && data.attachmentUrl.size() <= 1024));
    }

    function isValidLink(data) {
      return data.keys().hasAll(['title', 'url']) &&
             data.title is string && data.title.size() <= 200 &&
             data.url is string && data.url.size() <= 1024;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date']) &&
             data.title is string && data.title.size() <= 200 &&
             data.date is string && data.date.size() <= 100 &&
             (!('time' in data) || (data.time is string && data.time.size() <= 100)) &&
             (!('location' in data) || (data.location is string && data.location.size() <= 200));
    }

    function isValidAchievement(data) {
      return data.keys().hasAll(['title', 'year']) &&
             data.title is string && data.title.size() <= 200 &&
             data.year is string && data.year.size() <= 20 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000));
    }

    function isValidStudentHonor(data) {
      return data.keys().hasAll(['name', 'category', 'result']) &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 200 &&
             data.result is string && data.result.size() <= 200 &&
             (!('subtext' in data) || (data.subtext is string && data.subtext.size() <= 500)) &&
             (!('image' in data) || (data.image is string && data.image.size() <= 1024)) &&
             (!('order_index' in data) || (data.order_index is number));
    }

    function isValidMenu(data) {
      return data.keys().hasAll(['label', 'href', 'order_index']) &&
             data.label is string && data.label.size() <= 100 &&
             data.href is string && data.href.size() <= 1024 &&
             data.order_index is number &&
             (!('parent_id' in data) || (data.parent_id == null || data.parent_id is string));
    }

    // --- Collection Routes ---

    match /notices/{noticeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(noticeId) && isValidNotice(incoming());
      allow update: if isAdmin() && isValidId(noticeId) && isValidNotice(incoming());
      allow delete: if isAdmin() && isValidId(noticeId);
    }

    match /staff/{staffId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(staffId) && isValidStaff(incoming());
      allow update: if isAdmin() && isValidId(staffId) && isValidStaff(incoming());
      allow delete: if isAdmin() && isValidId(staffId);
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(itemId) && isValidGalleryItem(incoming());
      allow update: if isAdmin() && isValidId(itemId) && isValidGalleryItem(incoming());
      allow delete: if isAdmin() && isValidId(itemId);
    }

    match /carousel/{itemId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(itemId) && isValidGalleryItem(incoming());
      allow update: if isAdmin() && isValidId(itemId) && isValidGalleryItem(incoming());
      allow delete: if isAdmin() && isValidId(itemId);
    }

    match /fees/{feeId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(feeId) && isValidFee(incoming());
      allow update: if isAdmin() && isValidId(feeId) && isValidFee(incoming());
      allow delete: if isAdmin() && isValidId(feeId);
    }

    match /links/{linkId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(linkId) && isValidLink(incoming());
      allow update: if isAdmin() && isValidId(linkId) && isValidLink(incoming());
      allow delete: if isAdmin() && isValidId(linkId);
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(eventId) && isValidEvent(incoming());
      allow update: if isAdmin() && isValidId(eventId) && isValidEvent(incoming());
      allow delete: if isAdmin() && isValidId(eventId);
    }

    match /achievements/{achId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(achId) && isValidAchievement(incoming());
      allow update: if isAdmin() && isValidId(achId) && isValidAchievement(incoming());
      allow delete: if isAdmin() && isValidId(achId);
    }

    match /studentHonors/{honorId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(honorId) && isValidStudentHonor(incoming());
      allow update: if isAdmin() && isValidId(honorId) && isValidStudentHonor(incoming());
      allow delete: if isAdmin() && isValidId(honorId);
    }

    match /menu/{menuId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(menuId) && isValidMenu(incoming());
      allow update: if isAdmin() && isValidId(menuId) && isValidMenu(incoming());
      allow delete: if isAdmin() && isValidId(menuId);
    }

    match /admins/{uid} {
      // Allow the initial admin to bootstrap if the collection is empty (simplified for demo)
      // or check if specific email matches.
      allow read: if true; // Public list of admins is okay for this context
      allow write: if isAdmin() || (isSignedIn() && request.auth.token.email == 'ankur15121985@gmail.com');
    }
  }
}
